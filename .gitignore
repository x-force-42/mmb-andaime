# Repos dos projetos (vivem como submódulos lógicos, não físicos)
/mmb-core/
/mmb-cockpit/
/mmb-aquarium/

# Settings locais do Claude Code (por máquina)
/.claude/

# Mensagens da mailbox — audit trail efêmero, não esqueleto.
# Estrutura dos dirs preservada via .gitkeep.
/.tooling/inbox/*/*
!/.tooling/inbox/*/.gitkeep

# Épicos em curso — log de execução, não esqueleto.
/.tooling/intents/*
!/.tooling/intents/.gitkeep

# Logs estruturados (quando virarem realidade).
/.tooling/logs/*
!/.tooling/logs/.gitkeep

# Estado runtime do andaime (registry de agentes, heartbeats).
# Estrutura preservada via .gitkeep; conteúdo é runtime.
/.tooling/state/*
!/.tooling/state/.gitkeep
!/.tooling/state/heartbeats/
/.tooling/state/heartbeats/*
!/.tooling/state/heartbeats/.gitkeep

# Worktrees efêmeras que possam surgir na raiz
/.worktrees/

# Venv do aquario-bridge (runtime — recriável via aquario-bridge.sh)
/.tooling/aquario-bridge/.venv/
